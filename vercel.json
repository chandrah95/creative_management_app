{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["config/**"]
      }
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/css/(.*)", "dest": "/client/css/$1" },
    { "src": "/js/(.*)",  "dest": "/client/js/$1" },
    { "src": "/register",    "dest": "/client/register.html" },
    { "src": "/dashboard",   "dest": "/client/dashboard.html" },
    { "src": "/form",        "dest": "/client/form.html" },
    { "src": "/ai-settings", "dest": "/client/ai-settings.html" },
    { "src": "/",            "dest": "/client/login.html" }
  ]
}
