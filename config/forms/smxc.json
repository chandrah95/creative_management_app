{
  "id": "smxc",
  "name": "Social Media",
  "fields": [
    { "type": "input",       "name": "title",         "label": "Campaign Name",        "placeholder": "e.g. Ramadan Campaign", "required": true,  "width": "full" },
    { "type": "textarea",    "name": "description",   "label": "Description",          "placeholder": "What should this content communicate?", "required": false, "width": "full", "rows": 3 },
    { "type": "url",         "name": "brief_deck_url","label": "Brief Deck URL",        "placeholder": "https://...", "required": false, "width": "full" },
    { "type": "multiselect", "name": "platform",      "label": "Platform",             "required": true,  "width": "full",
      "options": [
        { "value": "instagram", "label": "Instagram" },
        { "value": "tiktok",    "label": "TikTok" },
        { "value": "others",    "label": "Others" }
      ]
    },
    { "type": "multiselect", "name": "posting_type",  "label": "Posting Type",         "required": true,  "width": "full",
      "options": [
        { "value": "reels", "label": "Reels" },
        { "value": "story", "label": "Story" },
        { "value": "post",  "label": "Post" }
      ]
    },
    { "type": "date",        "name": "posting_date",  "label": "Estimate Posting Date","required": false, "width": "half" }
  ],
  "childIssue": {
    "enabled": true,
    "label": "Add Content",
    "fields": [
      { "type": "dropdown", "name": "task_type",      "label": "Task Type",            "required": true,  "width": "half", "onchange": "window.taskTypeChanged(this)",
        "options": [
          { "value": "image",       "label": "Image" },
          { "value": "motion",      "label": "Motion" },
          { "value": "video",       "label": "Video" },
          { "value": "copywriting", "label": "Copywriting" }
        ]
      },
      { "type": "checkbox", "name": "is_need_studio", "label": "Needs Studio Team?",  "required": false, "width": "half" }
    ]
  }
}
