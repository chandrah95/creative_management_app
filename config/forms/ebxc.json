{
  "id": "ebxc",
  "name": "Existing Buyer",
  "fields": [
    { "type": "input",    "name": "title",          "label": "Campaign Title",        "placeholder": "e.g. Member Re-engagement Q2", "required": true,  "width": "full" },
    { "type": "textarea", "name": "description",    "label": "Campaign Brief",        "placeholder": "Describe the goal and message of this campaign", "required": true, "width": "full", "rows": 4 },
    { "type": "dropdown", "name": "campaign_type",  "label": "Campaign Type",         "required": true, "width": "half",
      "options": [
        { "value": "retention",   "label": "Retention" },
        { "value": "upsell",      "label": "Upsell" },
        { "value": "cross_sell",  "label": "Cross-sell" },
        { "value": "win_back",    "label": "Win-back" },
        { "value": "loyalty",     "label": "Loyalty Reward" }
      ]
    },
    { "type": "dropdown", "name": "priority",       "label": "Priority",              "required": true, "width": "half",
      "options": [
        { "value": "low",      "label": "Low" },
        { "value": "medium",   "label": "Medium" },
        { "value": "high",     "label": "High" },
        { "value": "critical", "label": "Critical" }
      ]
    },
    { "type": "date",     "name": "deadline",       "label": "Deadline",              "required": true,  "width": "half" },
    { "type": "number",   "name": "revisions",      "label": "Max Revisions",         "required": false, "width": "half", "min": 1, "max": 10, "default": 2 },
    { "type": "url",      "name": "reference_url",  "label": "Reference / Guideline", "placeholder": "https://...", "required": false, "width": "full" },
    { "type": "textarea", "name": "notes",          "label": "Additional Notes",      "placeholder": "Any special requirements...", "required": false, "width": "full", "rows": 3 }
  ],
  "childIssue": {
    "enabled": true,
    "label": "Add Asset",
    "fields": [
      { "type": "input",    "name": "child_title",  "label": "Asset Name",  "required": true,  "width": "full" },
      { "type": "dropdown", "name": "child_type",   "label": "Asset Type",  "required": true,  "width": "half",
        "options": [
          { "value": "banner",    "label": "Banner" },
          { "value": "email",     "label": "Email Template" },
          { "value": "push",      "label": "Push Notification Visual" },
          { "value": "voucher",   "label": "Voucher Design" },
          { "value": "other",     "label": "Other" }
        ]
      },
      { "type": "date",     "name": "child_due",        "label": "Due Date",           "required": false, "width": "half" },
      { "type": "checkbox", "name": "is_need_studio",       "label": "Needs Studio Team?",       "required": false, "width": "half" },
      { "type": "checkbox", "name": "is_need_copywriting",  "label": "Needs Copywriting?",       "required": false, "width": "half" },
      { "type": "textarea", "name": "child_notes",     "label": "Notes",              "required": false, "width": "full", "rows": 2 }
    ]
  }
}
