{
  "id": "ocsp",
  "name": "Offline Collateral",
  "fields": [
    { "type": "input",    "name": "title",         "label": "Campaign Name",  "placeholder": "e.g. Ramadan In-Store Poster", "required": true,  "width": "full" },
    { "type": "textarea", "name": "description",   "label": "Description",    "placeholder": "Describe what this collateral should communicate", "required": false, "width": "full", "rows": 3 },
    { "type": "url",      "name": "brief_deck_url","label": "Brief Deck URL", "placeholder": "https://...", "required": false, "width": "full" },
    { "type": "date",     "name": "live_date",     "label": "Live Date",      "required": true,  "width": "half" }
  ],
  "childIssue": {
    "enabled": true,
    "label": "Add Asset",
    "fields": [
      { "type": "dropdown", "name": "task_type", "label": "Task Type", "required": true, "width": "half", "onchange": "window.taskTypeChanged(this)",
        "options": [
          { "value": "product",     "label": "Product" },
          { "value": "copywriting", "label": "Copywriting" }
        ]
      },
      { "type": "dropdown", "name": "asset_type", "label": "Asset Type", "required": true, "width": "half",
        "options": [
          { "value": "flyer",           "label": "Flyer" },
          { "value": "box_carton",      "label": "Box/Carton" },
          { "value": "merchandise",     "label": "Merchandise" },
          { "value": "presentation",    "label": "Presentation Deck" },
          { "value": "poster",          "label": "Poster" },
          { "value": "tripod_banner",   "label": "Tripod Banner" },
          { "value": "spanduk",         "label": "Spanduk" },
          { "value": "billboard",       "label": "Billboard" },
          { "value": "physical_voucher","label": "Physical Voucher" },
          { "value": "sticker",         "label": "Sticker" },
          { "value": "catalogue",       "label": "Catalogue" },
          { "value": "mockup",          "label": "Mockup" },
          { "value": "special_project", "label": "Special Project" },
          { "value": "key_visual",      "label": "Key Visual" },
          { "value": "others",          "label": "Others" }
        ]
      },
      { "type": "checkbox", "name": "is_need_studio", "label": "Needs Studio Team?", "required": false, "width": "half" }
    ]
  }
}
