{
  "id": "print-offline",
  "name": "Print & Offline",
  "fields": [
    { "type": "input",    "name": "title",        "label": "Asset Title",             "placeholder": "e.g. A4 Event Flyer", "required": true, "width": "full" },
    { "type": "textarea", "name": "description",  "label": "Brief Description",       "placeholder": "What is this for? Key information to include...", "required": true, "width": "full", "rows": 4 },
    { "type": "dropdown", "name": "asset_type",   "label": "Print Asset Type",        "required": true, "width": "half",
      "options": [
        { "value": "flyer",     "label": "Flyer" },
        { "value": "brochure",  "label": "Brochure" },
        { "value": "poster",    "label": "Poster" },
        { "value": "banner",    "label": "Roll-up / Banner" },
        { "value": "card",      "label": "Business Card" },
        { "value": "packaging", "label": "Packaging" },
        { "value": "signage",   "label": "Signage" },
        { "value": "other",     "label": "Other" }
      ]
    },
    { "type": "dropdown", "name": "priority",     "label": "Priority",                "required": true, "width": "half",
      "options": [
        { "value": "low",      "label": "Low" },
        { "value": "medium",   "label": "Medium" },
        { "value": "high",     "label": "High" },
        { "value": "critical", "label": "Critical" }
      ]
    },
    { "type": "input",    "name": "size",         "label": "Final Size",              "placeholder": "e.g. A4, A3, 90x50mm", "required": true, "width": "half" },
    { "type": "number",   "name": "quantity",     "label": "Print Quantity",          "required": false, "width": "half", "min": 1, "max": 100000, "default": 100 },
    { "type": "date",     "name": "print_date",   "label": "Print / Event Date",      "required": true,  "width": "half" },
    { "type": "date",     "name": "deadline",     "label": "Artwork Deadline",        "required": true,  "width": "half" },
    { "type": "url",      "name": "reference_url","label": "Reference Link",          "placeholder": "https://...", "required": false, "width": "full" },
    { "type": "textarea", "name": "bleed_notes",  "label": "Print Specs / Notes",     "placeholder": "Bleed, safe zone, paper stock, finish...", "required": false, "width": "full", "rows": 3 }
  ],
  "childIssue": {
    "enabled": true,
    "label": "Add Language / Version",
    "fields": [
      { "type": "input",    "name": "child_title",    "label": "Version Title",      "required": true,  "width": "full" },
      { "type": "input",    "name": "child_language", "label": "Language",           "required": false, "width": "half" },
      { "type": "number",   "name": "child_quantity", "label": "Quantity",           "required": false, "width": "half", "min": 1, "default": 100 },
      { "type": "textarea", "name": "child_notes",    "label": "Notes",              "required": false, "width": "full", "rows": 2 }
    ]
  }
}
