{
  "id": "daxc",
  "name": "Digital Ads",
  "fields": [
    { "type": "input",    "name": "title",          "label": "Ad Campaign Title",     "placeholder": "e.g. Flash Sale Banner Set", "required": true,  "width": "full" },
    { "type": "textarea", "name": "description",    "label": "Campaign Brief",        "placeholder": "Describe the ad objective and key message", "required": true, "width": "full", "rows": 4 },
    { "type": "dropdown", "name": "ad_type",        "label": "Ad Format",             "required": true, "width": "half",
      "options": [
        { "value": "display_banner", "label": "Display Banner" },
        { "value": "video_ad",       "label": "Video Ad" },
        { "value": "native",         "label": "Native Ad" },
        { "value": "interstitial",   "label": "Interstitial" },
        { "value": "other",          "label": "Other" }
      ]
    },
    { "type": "dropdown", "name": "platform",       "label": "Ad Platform",           "required": true, "width": "half",
      "options": [
        { "value": "google",    "label": "Google Ads" },
        { "value": "meta",      "label": "Meta (FB/IG)" },
        { "value": "tiktok",    "label": "TikTok Ads" },
        { "value": "programmatic","label": "Programmatic" },
        { "value": "multi",     "label": "Multi-platform" }
      ]
    },
    { "type": "dropdown", "name": "priority",       "label": "Priority",              "required": true, "width": "half",
      "options": [
        { "value": "low",      "label": "Low" },
        { "value": "medium",   "label": "Medium" },
        { "value": "high",     "label": "High" },
        { "value": "critical", "label": "Critical" }
      ]
    },
    { "type": "date",     "name": "deadline",       "label": "Go-Live Date",          "required": true,  "width": "half" },
    { "type": "number",   "name": "revisions",      "label": "Max Revisions",         "required": false, "width": "half", "min": 1, "max": 10, "default": 2 },
    { "type": "url",      "name": "reference_url",  "label": "Reference / Brief URL", "placeholder": "https://...", "required": false, "width": "full" },
    { "type": "textarea", "name": "notes",          "label": "Additional Notes",      "required": false, "width": "full", "rows": 3 }
  ],
  "childIssue": {
    "enabled": true,
    "label": "Add Size Variant",
    "fields": [
      { "type": "input",    "name": "child_title",  "label": "Variant Name",    "placeholder": "e.g. Leaderboard 728x90", "required": true,  "width": "full" },
      { "type": "input",    "name": "child_type",   "label": "Dimensions (px)", "placeholder": "e.g. 728x90",            "required": true,  "width": "half" },
      { "type": "date",     "name": "child_due",        "label": "Due Date",           "required": false, "width": "half" },
      { "type": "checkbox", "name": "is_need_studio",  "label": "Needs Studio Team?", "required": false, "width": "half" },
      { "type": "textarea", "name": "child_notes",     "label": "Notes",              "required": false, "width": "full", "rows": 2 }
    ]
  }
}
