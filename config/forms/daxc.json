{
  "id": "daxc",
  "name": "Digital Ads",
  "fields": [
    { "type": "input",    "name": "title",         "label": "Campaign Name",  "placeholder": "e.g. Flash Sale Banner Set", "required": true,  "width": "full" },
    { "type": "textarea", "name": "description",   "label": "Description",    "placeholder": "Describe the ad objective and key message", "required": false, "width": "full", "rows": 3 },
    { "type": "url",      "name": "brief_deck_url","label": "Brief Deck URL", "placeholder": "https://...", "required": false, "width": "full" }
  ],
  "childIssue": {
    "enabled": true,
    "label": "Add Asset",
    "fields": [
      { "type": "dropdown", "name": "task_type", "label": "Task Type", "required": true, "width": "half", "onchange": "window.taskTypeChanged(this)",
        "options": [
          { "value": "image",       "label": "Image" },
          { "value": "motion",      "label": "Motion" },
          { "value": "video",       "label": "Video" },
          { "value": "copywriting", "label": "Copywriting" }
        ]
      },
      { "type": "dropdown", "name": "objective_type", "label": "Objective Type", "required": true, "width": "half",
        "options": [
          { "value": "awareness",    "label": "Awareness" },
          { "value": "consideration","label": "Consideration" },
          { "value": "conversion",   "label": "Conversion" }
        ]
      },
      { "type": "checkbox", "name": "is_need_studio", "label": "Needs Studio Team?", "required": false, "width": "half" }
    ]
  }
}
