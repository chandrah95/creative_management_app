{
  "id": "pac",
  "name": "Packaging",
  "fields": [
    { "type": "input",    "name": "title",          "label": "SKU Name",       "placeholder": "e.g. Astro Cafe Latte 250ml", "required": true,  "width": "half" },
    { "type": "input",    "name": "sku_number",     "label": "SKU Number",     "placeholder": "e.g. SKU-001234",            "required": true,  "width": "half" },
    { "type": "dropdown", "name": "packaging_type", "label": "Packaging Type", "required": true, "width": "half",
      "options": [
        { "value": "box",     "label": "Box" },
        { "value": "pouch",   "label": "Pouch" },
        { "value": "bag",     "label": "Bag" },
        { "value": "tube",    "label": "Tube" },
        { "value": "bottle",  "label": "Bottle" },
        { "value": "bowl",    "label": "Bowl" },
        { "value": "wrapper", "label": "Wrapper" }
      ]
    },
    { "type": "dropdown", "name": "brand",          "label": "Brand",          "required": true, "width": "half",
      "options": [
        { "value": "abasics",      "label": "Abasics" },
        { "value": "astro_goods",  "label": "Astro Goods" },
        { "value": "astro_cafe",   "label": "Astro Cafe" },
        { "value": "astro_bakery", "label": "Astro Bakery" },
        { "value": "astro_farm",   "label": "Astro Farm" }
      ]
    },
    { "type": "textarea", "name": "description",    "label": "Description",    "placeholder": "Describe packaging requirements and key info", "required": false, "width": "full", "rows": 3 },
    { "type": "url",      "name": "brief_deck_url", "label": "Brief Deck URL", "placeholder": "https://...", "required": false, "width": "full" },
    { "type": "date",     "name": "live_date",      "label": "Live Date",      "required": true,  "width": "half" },
    { "type": "multitext", "name": "dimensions",    "label": "Dimensions",     "placeholder": "e.g. 100x200x50mm", "required": false, "width": "full" }
  ],
  "childIssue": {
    "enabled": true,
    "label": "Add SKU",
    "fields": [
      { "type": "dropdown", "name": "task_type", "label": "Task Type", "required": true, "width": "half", "onchange": "window.taskTypeChanged(this)",
        "options": [
          { "value": "packaging",   "label": "Packaging" },
          { "value": "copywriting", "label": "Copywriting" }
        ]
      },
      { "type": "checkbox", "name": "is_need_studio", "label": "Needs Studio Team?", "required": false, "width": "half" }
    ]
  }
}
