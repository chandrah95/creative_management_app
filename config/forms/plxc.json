{
  "id": "plxc",
  "name": "Private Label",
  "fields": [
    { "type": "input",    "name": "title",          "label": "Request Title",         "placeholder": "e.g. PL Brand Identity Refresh", "required": true,  "width": "full" },
    { "type": "textarea", "name": "description",    "label": "Brief",                 "placeholder": "Describe the design need in detail", "required": true, "width": "full", "rows": 4 },
    { "type": "input",    "name": "product_name",   "label": "Product / Brand Name",  "placeholder": "e.g. Natura Essentials", "required": true,  "width": "half" },
    { "type": "dropdown", "name": "asset_type",     "label": "Asset Type",            "required": true, "width": "half",
      "options": [
        { "value": "logo",         "label": "Logo" },
        { "value": "brand_guide",  "label": "Brand Guide" },
        { "value": "label_design", "label": "Label Design" },
        { "value": "tag",          "label": "Hang Tag / Sticker" },
        { "value": "other",        "label": "Other" }
      ]
    },
    { "type": "dropdown", "name": "priority",       "label": "Priority",              "required": true, "width": "half",
      "options": [
        { "value": "low",      "label": "Low" },
        { "value": "medium",   "label": "Medium" },
        { "value": "high",     "label": "High" },
        { "value": "critical", "label": "Critical" }
      ]
    },
    { "type": "date",     "name": "deadline",       "label": "Deadline",              "required": true,  "width": "half" },
    { "type": "number",   "name": "revisions",      "label": "Max Revisions",         "required": false, "width": "half", "min": 1, "max": 10, "default": 2 },
    { "type": "url",      "name": "reference_url",  "label": "Reference / Moodboard", "placeholder": "https://...", "required": false, "width": "full" },
    { "type": "textarea", "name": "notes",          "label": "Additional Notes",      "required": false, "width": "full", "rows": 3 }
  ],
  "childIssue": {
    "enabled": true,
    "label": "Add Deliverable",
    "fields": [
      { "type": "input",    "name": "child_title",   "label": "Deliverable Name", "required": true,  "width": "full" },
      { "type": "dropdown", "name": "child_type",    "label": "File Type",        "required": true,  "width": "half",
        "options": [
          { "value": "ai",   "label": "Adobe Illustrator (.ai)" },
          { "value": "pdf",  "label": "PDF" },
          { "value": "png",  "label": "PNG" },
          { "value": "jpeg", "label": "JPEG" },
          { "value": "other","label": "Other" }
        ]
      },
      { "type": "date",     "name": "child_due",     "label": "Due Date",         "required": false, "width": "half" },
      { "type": "textarea", "name": "child_notes",   "label": "Notes",            "required": false, "width": "full", "rows": 2 }
    ]
  }
}
